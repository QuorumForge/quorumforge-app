# Soroban RPC endpoints
NEXT_PUBLIC_SOROBAN_RPC_TESTNET=https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_MAINNET=https://soroban-mainnet.stellar.org

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/quorumforge

# App URL (used for OG image generation and webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: webhook URL for proposal notifications
NOTIFICATION_WEBHOOK_URL=
